---
import Layout from "../layouts/Layout.astro";
import { actions } from 'astro:actions';
import Recaptcha from '../components/Recaptcha.jsx';
import SubmitButton from '../components/SubmmitButton';
const result = Astro.getActionResult(actions.enviarCorreo);
---

<Layout>
  <section class="max-w-5xl mx-auto px-6">

    <div class="mb-10">
      <div class="terminal-badge">Demostración</div>
      <h1 class="text-4xl font-bold text-stone-800 tracking-tight leading-none mb-3">
        APIs Externas - Verificación <span class="text-amber-600">reCAPTCHA</span> v2
      </h1>
      <p class="text-sm text-stone-500 leading-relaxed max-w-lg">
        Demostración del flujo completo: widget de Google → token → verificación
        en servidor → envío de correo vía Nodemailer + SendGrid.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8 items-start">

      <!-- Formulario -->
      <div class="box-style">

        <div class="mb-6 pb-4 border-b border-stone-200">
          <p class="text-xs font-semibold text-stone-400 uppercase tracking-widest">
            contacto.astro — formulario
          </p>
        </div>

        {result?.error && (
          <div class="contact-alert contact-alert-error">
            <p class="font-semibold mb-0.5">Error: acción fallida</p>
            <p class="opacity-80">{result.error.message}</p>
          </div>
        )}

        {result?.data?.success && (
          <div class="contact-alert contact-alert-success">
            <p class="font-semibold mb-0.5">✓ Correo enviado correctamente</p>
            <p class="opacity-70">El mensaje ha sido procesado y enviado.</p>
          </div>
        )}

        <form
          method="POST"
          action={actions.enviarCorreo}
          enctype="multipart/form-data"
          class="flex flex-col gap-5"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <label class="contact-label">
              <span>Nombre</span>
              <input type="text" name="nombre" required class="contact-input" placeholder="Tu nombre" />
            </label>

            <label class="contact-label">
              <span>Email</span>
              <input type="email" name="email" required class="contact-input" placeholder="tu@correo.com" />
            </label>
          </div>

          <label class="contact-label">
            <span>Asunto</span>
            <input type="text" name="asunto" required class="contact-input" placeholder="Motivo del mensaje" />
          </label>

          <label class="contact-label">
            <span>Imagen adjunta <span class="normal-case font-normal">(opcional · máx. 512 KB)</span></span>
            <input type="file" accept="image/*" name="imagen" class="contact-input" />
          </label>

          <label class="contact-label">
            <span>Mensaje</span>
            <textarea name="mensaje" rows="5" required class="contact-textarea" placeholder="Escribe tu mensaje..."></textarea>
          </label>

          <div class="border border-stone-200 rounded-lg p-4 bg-white">
            <p class="text-xs font-semibold text-stone-400 uppercase tracking-widest mb-3">
              Verificación de seguridad
            </p>
            <Recaptcha
              client:only="react"
              siteKey={import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY}
            />
            <input type="hidden" id="g-recaptcha-response" name="g-recaptcha-response" />
          </div>

          <SubmitButton client:only="react" />
        </form>
      </div>

      <!-- Columna derecha: flujo -->
      <div class="flex flex-col gap-3">

        <p class="text-xs font-bold text-stone-500 uppercase tracking-widest mb-1">
          Flujo de verificación
        </p>

        <div class="flow-step">
          <div class="flow-step-num">01 — cliente</div>
          <div class="flow-step-title">Widget cargado</div>
          <div class="flow-step-desc">
            <code class="text-amber-600">recaptchaLoader.js</code> inyecta
            el script de Google con <code class="text-stone-500">render=explicit</code>.
          </div>
        </div>

        <div class="flex justify-center">
          <div class="w-px h-5 bg-gradient-to-b from-amber-300 to-transparent"></div>
        </div>

        <div class="flow-step">
          <div class="flow-step-num">02 — usuario</div>
          <div class="flow-step-title">Checkbox marcado</div>
          <div class="flow-step-desc">
            Google devuelve un <span class="text-amber-600 font-semibold">token temporal</span> almacenado en el
            <code class="text-stone-500">input hidden</code>.
            El botón se activa vía <code class="text-stone-500">recaptcha:verified</code>.
          </div>
        </div>

        <div class="flex justify-center">
          <div class="w-px h-5 bg-gradient-to-b from-amber-300 to-transparent"></div>
        </div>

        <div class="flow-step">
          <div class="flow-step-num">03 — servidor</div>
          <div class="flow-step-title">Astro Action</div>
          <div class="flow-step-desc">
            El token viaja con el <code class="text-stone-500">POST multipart</code>.
            Se llama a <code class="text-amber-600">siteverify</code> con la clave secreta.
            Si responde <code class="text-stone-500">success: true</code>, continúa.
          </div>
        </div>

        <div class="flex justify-center">
          <div class="w-px h-5 bg-gradient-to-b from-amber-300 to-transparent"></div>
        </div>

        <div class="flow-step">
          <div class="flow-step-num">04 — envío</div>
          <div class="flow-step-title">Nodemailer + SendGrid</div>
          <div class="flow-step-desc">
            <code class="text-amber-600">createTransport</code> con SMTP de
            SendGrid. El correo se envía con mensaje y adjunto opcional.
          </div>
        </div>

        <div class="mt-1 bg-white border border-stone-300 rounded-xl p-4">
          <p class="text-xs font-bold text-stone-500 uppercase tracking-widest mb-3">
            Variables de entorno
          </p>
          <div class="flex flex-col gap-1.5 text-xs">
            <div><span class="text-amber-600 font-semibold">PUBLIC_</span><span class="text-stone-600">RECAPTCHA_SITE_KEY</span></div>
            <div class="text-stone-400 pl-2 text-[0.65rem]">→ navegador · monta el widget</div>
            <div class="mt-1"><span class="text-red-500 font-semibold">RECAPTCHA</span><span class="text-stone-600">_SECRET</span></div>
            <div class="text-stone-400 pl-2 text-[0.65rem]">→ servidor · verifica el token</div>
            <div class="mt-1 text-stone-600 font-medium">EMAIL_HOST / PASS / FROM</div>
            <div class="text-stone-400 pl-2 text-[0.65rem]">→ servidor · envía el correo</div>
          </div>
        </div>

      </div>
    </div>

  </section>
</Layout>